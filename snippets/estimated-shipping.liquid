<dynamic-dates
  class="estimated-shipping{% if block.settings.icon_alignment == 'middle' %} estimated-shipping--align-center{% endif %}"
  data-date-format="{{ block.settings.date_format }}"
  data-day-labels=""
  data-month-labels=""
  {{ block.shopify_attributes }}
  style="--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;"
>
  {% unless block.settings.custom_icon == blank and block.settings.icon == blank %}
    <div class="estimated-shipping__icon estimated-shipping__icon--{{ block.settings.icon_size }}">
      {% if block.settings.custom_icon != blank %}
        <img
          src="{{ block.settings.custom_icon | image_url: width: 150 }}"
          width="auto"
          height="auto"
          loading="lazy"
        >
      {% else %}
        {% render 'material-icon', icon: block.settings.icon, filled: block.settings.filled_icon %}
      {% endif %}
    </div>
  {% endunless %}
  <div
    class="estimated-shipping__text estimated-shipping__text--{{ block.settings.text_size }}"
    data-dynamic-date="true"
    data-text="{{ block.settings.message }}"
    data-min-days="{{ block.settings.min_shipping_days }}"
    data-max-days="{{ block.settings.max_shipping_days }}"
  >
    {{ block.settings.message | replace: '[start_date]', '-' | replace: '[end_date]', '-' }}
  </div>

  <script>
    (function () {
      const parent = document.currentScript.parentElement;
      const textEl = parent.querySelector('.estimated-shipping__text');
      const locale = {{ localization.language.iso_code | json }} || 'en';
      const dateFormat = {{ block.settings.date_format | json }} || 'long';
      const minDays = parseInt(textEl.dataset.minDays, 10) || 0;
      const maxDays = parseInt(textEl.dataset.maxDays, 10) || 0;

      // Generate localized day labels for DynamicDates compatibility
      const dayFormatter = new Intl.DateTimeFormat(locale, { weekday: 'long' });
      const days = [];
      for (let i = 0; i < 7; i++) {
        const d = new Date(2024, 0, i + 1);
        days.push(dayFormatter.format(d));
      }
      parent.dataset.dayLabels = days.join(',');

      // Generate localized month labels for DynamicDates compatibility
      const monthFormatter = new Intl.DateTimeFormat(locale, { month: 'long' });
      const months = [];
      for (let i = 0; i < 12; i++) {
        const d = new Date(2024, i, 1);
        months.push(monthFormatter.format(d));
      }
      parent.dataset.monthLabels = months.join(',');

      // Calculate dates
      const today = new Date();
      const startDate = new Date(today);
      startDate.setDate(today.getDate() + minDays);
      const endDate = new Date(today);
      endDate.setDate(today.getDate() + maxDays);

      // Format dates based on selected format
      let startFormatted, endFormatted;
      
      switch (dateFormat) {
        case 'long':
          startFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' }).format(endDate);
          break;
        case 'day_month':
          startFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long' }).format(endDate);
          break;
        case 'month_day':
          startFormatted = new Intl.DateTimeFormat(locale, { day: 'numeric', month: 'long' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { day: 'numeric', month: 'long' }).format(endDate);
          break;
        case 'medium':
          startFormatted = new Intl.DateTimeFormat(locale, { day: 'numeric', month: 'short', year: 'numeric' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { day: 'numeric', month: 'short', year: 'numeric' }).format(endDate);
          break;
        case 'numeric':
          startFormatted = new Intl.DateTimeFormat(locale, { day: '2-digit', month: '2-digit', year: 'numeric' }).format(startDate).replace(/\//g, '.');
          endFormatted = new Intl.DateTimeFormat(locale, { day: '2-digit', month: '2-digit', year: 'numeric' }).format(endDate).replace(/\//g, '.');
          break;
        case 'short':
          startFormatted = new Intl.DateTimeFormat(locale, { day: '2-digit', month: '2-digit', year: 'numeric' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { day: '2-digit', month: '2-digit', year: 'numeric' }).format(endDate);
          break;
        default:
          startFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long' }).format(endDate);
      }

      // Carrier replacement logic
      const country = {{ localization.country.iso_code | json }};
      const carrierListRaw = {{ block.settings.carrier_list | json }};
      const carrierPrefix = {{ block.settings.carrier_prefix | json }};
      const carrierFallback = {{ block.settings.carrier_fallback | json }};

      const map = {};
      if (carrierListRaw) {
        carrierListRaw.split('\n').forEach(function (line) {
          const idx = line.indexOf(':');
          if (idx > -1) {
            const code = line.slice(0, idx).trim().toUpperCase();
            const name = line.slice(idx + 1).trim();
            map[code] = name;
          }
        });
      }

      const carrierName = map[country] || carrierFallback || '';
      const carrierDisplay = carrierName
        ? (carrierPrefix ? carrierPrefix + ' ' + carrierName : carrierName)
        : '';

      function applyReplacements() {
        let html = textEl.innerHTML;
        if (html.includes('[start_date]')) {
          html = html.replace(/\[start_date\]/g, startFormatted);
        }
        if (html.includes('[end_date]')) {
          html = html.replace(/\[end_date\]/g, endFormatted);
        }
        if (html.includes('[carrier]')) {
          if (carrierDisplay) {
            html = html.replace(/\[carrier\]/g, carrierDisplay);
          } else {
            html = html.replace(/\s*\[carrier\]/g, '');
          }
        }
        textEl.innerHTML = html;
      }

      const observer = new MutationObserver(function () {
        applyReplacements();
      });
      observer.observe(textEl, { childList: true, characterData: true, subtree: true });

      applyReplacements();
    })();
  </script>
</dynamic-dates>
