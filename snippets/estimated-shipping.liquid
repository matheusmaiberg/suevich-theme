<dynamic-dates
  class="estimated-shipping{% if block.settings.icon_alignment == 'middle' %} estimated-shipping--align-center{% endif %}"
  data-date-format="{{ block.settings.date_format }}"
  data-day-labels=""
  data-month-labels=""
  {{ block.shopify_attributes }}
  style="--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;"
>
  {% unless block.settings.custom_icon == blank and block.settings.icon == blank %}
    <div class="estimated-shipping__icon estimated-shipping__icon--{{ block.settings.icon_size }}">
      {% if block.settings.custom_icon != blank %}
        <img
          src="{{ block.settings.custom_icon | image_url: width: 150 }}"
          width="auto"
          height="auto"
          loading="lazy"
        >
      {% else %}
        {% render 'material-icon', icon: block.settings.icon, filled: block.settings.filled_icon %}
      {% endif %}
    </div>
  {% endunless %}
  <div
    class="estimated-shipping__text estimated-shipping__text--{{ block.settings.text_size }}"
    data-dynamic-date="true"
    data-text="{{ block.settings.message }}"
    data-min-days="{{ block.settings.min_shipping_days }}"
    data-max-days="{{ block.settings.max_shipping_days }}"
  >
    {{ block.settings.message | replace: '[start_date]', '-' | replace: '[end_date]', '-' }}
  </div>

  <script>
    (function () {
      const parent = document.currentScript.parentElement;
      const locale = {{ localization.language.iso_code | json }} || 'en';

      // Generate localized day labels for DynamicDates
      const dayFormatter = new Intl.DateTimeFormat(locale, { weekday: 'long' });
      const days = [];
      for (let i = 0; i < 7; i++) {
        const d = new Date(2024, 0, i + 1);
        days.push(dayFormatter.format(d));
      }
      parent.dataset.dayLabels = days.join(',');

      // Generate localized month labels for DynamicDates
      const monthFormatter = new Intl.DateTimeFormat(locale, { month: 'long' });
      const months = [];
      for (let i = 0; i < 12; i++) {
        const d = new Date(2024, i, 1);
        months.push(monthFormatter.format(d));
      }
      parent.dataset.monthLabels = months.join(',');

      // Carrier replacement logic
      const textEl = parent.querySelector('.estimated-shipping__text');
      if (!textEl || !textEl.dataset.text || !textEl.dataset.text.includes('[carrier]')) return;

      const country = {{ localization.country.iso_code | json }};
      const carrierListRaw = {{ block.settings.carrier_list | json }};
      const carrierPrefix = {{ block.settings.carrier_prefix | json }};
      const carrierFallback = {{ block.settings.carrier_fallback | json }};

      const map = {};
      if (carrierListRaw) {
        carrierListRaw.split('\n').forEach(function (line) {
          const idx = line.indexOf(':');
          if (idx > -1) {
            const code = line.slice(0, idx).trim().toUpperCase();
            const name = line.slice(idx + 1).trim();
            map[code] = name;
          }
        });
      }

      const carrierName = map[country] || carrierFallback || '';
      const carrierDisplay = carrierName
        ? (carrierPrefix ? carrierPrefix + ' ' + carrierName : carrierName)
        : '';

      function applyCarrier() {
        if (!textEl.innerHTML.includes('[carrier]')) return;
        if (carrierDisplay) {
          textEl.innerHTML = textEl.innerHTML.replace(/\[carrier\]/g, carrierDisplay);
        } else {
          textEl.innerHTML = textEl.innerHTML.replace(/\s*\[carrier\]/g, '');
        }
      }

      const observer = new MutationObserver(function () {
        applyCarrier();
      });
      observer.observe(textEl, { childList: true, characterData: true, subtree: true });

      applyCarrier();
    })();
  </script>
</dynamic-dates>
