    "ss_testimonial_14_3hnAwq": {
      "type": "ss-testimonial-14",
      "blocks": {
        "slide_PibBBg": {
          "type": "slide",
          "settings": {
            "image": "shopify://shop_images/25.png",
            "text": "<p>Einfach traumhaft! Die Pantoffeln sind weich, warm und kamen super schnell an. Wirklich top!</p>",
            "author": "Anna Müller"
          }
        },
        "slide_TQBxi8": {
          "type": "slide",
          "settings": {
            "image": "shopify://shop_images/22_b130479f-9553-46bf-bcc6-1f9e3344c937.png",
            "text": "<p>So bequem und warm! Ich trage sie jeden Abend. Lieferung war in nur 3 Tagen da.</p>",
            "author": "Lena Schneider"
          }
        },
        "slide_KxfBb7": {
          "type": "slide",
          "settings": {
            "image": "shopify://shop_images/24_b3aa3e43-28d9-4b6c-bc8f-87615510535f.png",
            "text": "<p>Perfekte Größe, tolle Qualität! Habe gleich zwei Paare bestellt. Die Farbe ist wunderschön.</p>",
            "author": "Julia Weber S."
          }
        },
        "slide_hT9fJH": {
          "type": "slide",
          "settings": {
            "image": "shopify://shop_images/20_a20315ec-a430-4770-b2d2-575a2632146a.png",
            "text": "<p>Die Pantoffeln sind so warm und flauschig. Ideal für kalte Tage! Lieferung war blitzschnell.</p>",
            "author": "Maria H."
          }
        },
        "slide_HrRj43": {
          "type": "slide",
          "settings": {
            "image": "shopify://shop_images/21_962f5123-cb22-4d30-b8d6-2f04f07bc134.png",
            "text": "<p>Ich habe sie meiner Mutter geschenkt, sie liebt sie! Wirklich sehr weich und bequem.</p>",
            "author": "Sarah B."
          }
        },
        "slide_KQnxNQ": {
          "type": "slide",
          "settings": {
            "image": "shopify://shop_images/20_a20315ec-a430-4770-b2d2-575a2632146a.png",
            "text": "<p>Super Qualität, sehen toll aus! Ich bestelle gleich noch ein Paar in einer anderen Farbe.</p>",
            "author": "Katharina Fischer"
          }
        },
        "slide_yyLCng": {
          "type": "slide",
