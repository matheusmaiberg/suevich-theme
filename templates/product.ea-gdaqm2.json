            "custom_liquid": "<div id=\"ss-trust-card\" class=\"trust-box\">\n  <div class=\"trust-images\">\n    <img class=\"trust-image\" src=\"https://cdn.shopify.com/s/files/1/0638/0139/3241/files/download_bed09d39-c6ac-4b64-a7ae-5e2aff7de478.jpg?v=1770231066\" alt=\"James\">\n    <img class=\"trust-image trust-image--overlap\" src=\"https://cdn.shopify.com/s/files/1/0638/0139/3241/files/download_22.jpg?v=1770231102\" alt=\"Emily\">\n  </div>\n\n  <div class=\"trust-box-wrapper\">\n\n    {% assign lang = request.locale.iso_code %}\n\n    {% if lang contains 'nl' %}\n      {% assign text_and = 'en' %}\n      {% assign text_count = 'meer dan 25.550' %}\n      {% assign text_choose = 'anderen kiezen' %}\n      {% assign text_reviews = 'Lees hier alle beoordelingen' %}\n    {% elsif lang contains 'en' %}\n      {% assign text_and = 'and' %}\n      {% assign text_count = 'over 25,550' %}\n      {% assign text_choose = 'others choose' %}\n      {% assign text_reviews = 'Read all reviews here' %}\n    {% else %}\n      {% assign text_and = 'und' %}\n      {% assign text_count = 'über 25.550' %}\n      {% assign text_choose = 'andere wählen' %}\n      {% assign text_reviews = 'Alle Bewertungen hier lesen' %}\n    {% endif %}\n\n    <p class=\"trust-text\">\n      <strong>Alexandre</strong>, \n      <strong>Julien</strong> \n      {{ text_and }} \n      <strong>{{ text_count }}</strong> \n      {{ text_choose }} \n      <strong>Suevich</strong>\n    </p>\n\n    <a href=\"#a2-reviews-widget\" class=\"trust-link scroll-link\">\n      {{ text_reviews }}\n    </a>\n  </div>\n\n<style>\n#ss-trust-card{\n  display:flex;\n  align-items:center;\n  gap:10px;\n  background:#E4EDF7;\n  padding:6px 12px;\n  border-radius:6px;\n  margin-top:12px!important;\n  margin-bottom:12px!important;\n  color:#0B1624;\n  font-size:19px;\n  line-height:1.4;\n}\n\n#ss-trust-card .trust-images{\n  display:flex;\n  align-items:center;\n}\n\n#ss-trust-card .trust-image{\n  width:38px;\n  height:38px;\n  min-width:38px;\n  min-height:38px;\n  border-radius:50%;\n  object-fit:cover;\n  border:2px solid #fff;\n  display:block;\n}\n\n#ss-trust-card .trust-image--overlap{\n  margin-left:-14px;\n}\n\n#ss-trust-card .trust-text{\n  margin:0;\n  font-size:12px;\n}\n\n#ss-trust-card .trust-link{\n  display:inline-block;\n  margin-top:2px;\n  font-size:12px;\n  font-weight:600;\n  color:#6B7280;\n  text-decoration:none;\n}\n\n#ss-trust-card .trust-link:hover{\n  opacity:.85;\n}\n</style>\n\n<script>\n(function () {\n\n  function getHeaderOffset() {\n    const header = document.querySelector('[data-sticky], .shopify-section-header, header');\n    return (header ? header.offsetHeight : 0) + 12;\n  }\n\n  function scrollToA2Reviews() {\n    const target = document.querySelector('#a2-reviews-widget');\n    if (!target) return false;\n\n    const y = target.getBoundingClientRect().top + window.pageYOffset - getHeaderOffset();\n\n    window.scrollTo({\n      top: y < 0 ? 0 : y,\n      behavior: 'smooth'\n    });\n\n    return true;\n  }\n\n  function scrollWithRetry() {\n    let tries = 0;\n    const maxTries = 30;\n\n    const timer = setInterval(function () {\n      tries++;\n\n      if (scrollToA2Reviews()) {\n        clearInterval(timer);\n        setTimeout(scrollToA2Reviews, 350);\n      }\n\n      if (tries >= maxTries) {\n        clearInterval(timer);\n        console.warn('A2Reviews não encontrado (#a2-reviews-widget).');\n      }\n    }, 200);\n  }\n\n  document.addEventListener('click', function (e) {\n    const link = e.target.closest('.scroll-link');\n    if (!link) return;\n\n    e.preventDefault();\n    scrollWithRetry();\n  });\n\n})();\n</script>\n\n</div>"
