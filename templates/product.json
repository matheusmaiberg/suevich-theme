        "custom_liquid_yCR8a3": {
          "type": "custom_liquid",
          "name": "Oferta: Risco Zero",
          "settings": {
            "custom_liquid": "{%- assign lang = request.locale.iso_code -%}\n{%- assign shop_name = shop.name | default: 'Our' -%}\n\n{%- if lang == 'de' -%}\n  {%- assign text_title = \"Das \" | append: shop.name | append: \" Null-Risiko-Versprechen\" -%}\n  {%- assign text_icon1 = \"Kostenloser Versand\" -%}\n  {%- assign text_icon2 = \"19% MwSt. Inkl.\" -%}\n  {%- assign text_icon3 = \"30 Tage Test\" -%}\n  {%- assign text_icon4 = \"Einfache Retouren\" -%}\n  {%- assign text_intro = \"Ein 2-Minuten-Test vor dem Spiegel reicht nicht aus, um ein Kleidungsstück wirklich zu beurteilen. Deshalb haben wir unser Null-Risiko-Versprechen entwickelt, um Ihnen absolute Sicherheit zu geben:\" -%}\n  {%- assign text_li1 = \"<strong>Kostenloser Versand:</strong> Lieferung direkt an Ihre Haustür mit Sendungsverfolgung.\" -%}\n  {%- assign text_li2 = \"<strong>19% MwSt. Inklusive:</strong> Keine versteckten Zollgebühren oder böse Überraschungen bei der Zustellung.\" -%}\n  {%- assign text_li3 = \"<strong>30 Tage Trage-Garantie:</strong> Testen Sie Ihre \" | append: shop_name | append: \" Artikel im echten Alltag – im Büro oder am Wochenende. Wenn es nicht Ihr neues Lieblingsteil wird, erstatten wir Ihnen den vollen Kaufpreis.\" -%}\n  {%- assign text_li4 = \"<strong>Einfache Retouren:</strong> Unkompliziert, schnell und ohne Diskussionen.\" -%}\n{%- else -%}\n  {%- assign text_title = \"The \" | append: shop_name | append: \" Risk-Free Promise\" -%}\n  {%- assign text_icon1 = \"Free Shipping\" -%}\n  {%- assign text_icon2 = \"VAT Included\" -%}\n  {%- assign text_icon3 = \"30-Day Trial\" -%}\n  {%- assign text_icon4 = \"Easy Returns\" -%}\n  {%- assign text_intro = \"Trying on clothes for two minutes in front of a mirror isn't enough to know if they truly fit your lifestyle. That’s why we created our Risk-Free Promise to ensure absolute peace of mind:\" -%}\n  {%- assign text_li1 = \"<strong>Free Shipping:</strong> Delivered straight to your door with end-to-end tracking.\" -%}\n  {%- assign text_li2 = \"<strong>VAT Included:</strong> No hidden customs fees or surprise charges upon delivery.\" -%}\n  {%- assign text_li3 = \"<strong>30-Day Real-World Trial:</strong> Actually wear your \" | append: shop_name | append: \" pieces in the real world—at the office or during weekends. If they don't become the most comfortable items in your wardrobe, send them back.\" -%}\n  {%- assign text_li4 = \"<strong>Hassle-Free Returns:</strong> Simple, fast, and no questions asked.\" -%}\n{%- endif -%}\n\n<style>\n  /* Escopo fechado com prefixo 'suevich' para não dar conflito com o seu tema */\n  .suevich-promise-wrapper {\n    margin: 1.5rem 0;\n    color: inherit;\n    font-family: inherit;\n  }\n  \n  .suevich-promise-grid {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));\n    gap: 1rem;\n    margin-bottom: 1.5rem;\n  }\n  \n  .suevich-promise-item {\n    display: flex;\n    align-items: center;\n    justify-content: center; /* Centraliza os ícones e o texto na grelha */\n    gap: 8px;\n    font-size: clamp(12px, 1vw, 13px);\n    opacity: 0.85;\n  }\n  \n  .suevich-promise-icon {\n    width: 16px;\n    height: 16px;\n    flex-shrink: 0;\n    stroke: currentColor;\n  }\n\n  /* Acordeão Nativo Centralizado com Setas Duplas */\n  .suevich-details {\n    border-top: 1px solid rgba(128, 128, 128, 0.25);\n    border-bottom: 1px solid rgba(128, 128, 128, 0.25);\n  }\n  \n  .suevich-summary {\n    display: flex;\n    justify-content: space-between; /* Empurra as setas para as bordas e centraliza o meio */\n    align-items: center;\n    padding: 1.2rem 0;\n    cursor: pointer;\n    list-style: none; /* Remove a setinha padrão do HTML */\n  }\n  \n  .suevich-summary::-webkit-details-marker {\n    display: none; /* Remove a setinha no Safari */\n  }\n\n  /* Wrapper para o Badge e o Texto no centro */\n  .suevich-summary-content {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    font-size: clamp(13px, 1.2vw, 15px);\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n  }\n\n  .suevich-police-badge {\n    width: 18px;\n    height: 18px;\n    stroke: currentColor;\n    flex-shrink: 0;\n  }\n  \n  .suevich-accordion-icon-arrow {\n    width: 14px;\n    height: 14px;\n    transition: transform 0.3s ease;\n    opacity: 0.7;\n    flex-shrink: 0;\n  }\n  \n  /* Anima as DUAS setas quando o acordeão HTML abre */\n  .suevich-details[open] .suevich-accordion-icon-arrow {\n    transform: rotate(180deg);\n  }\n  \n  .suevich-details-content {\n    padding-bottom: 1.5rem;\n    font-size: clamp(13px, 1vw, 14px);\n    line-height: 1.6;\n    opacity: 0.85;\n    text-align: left; /* Voltou para o alinhamento à esquerda padrão */\n  }\n\n  .suevich-details-content ul {\n    margin-top: 12px;\n    padding-left: 20px;\n    margin-bottom: 0;\n  }\n\n  .suevich-details-content li {\n    margin-bottom: 8px;\n  }\n\n  /* Força o negrito absoluto contra o CSS do tema */\n  .suevich-details-content strong {\n    font-weight: bold !important;\n  }\n</style>\n\n<div class=\"suevich-promise-wrapper\">\n\n  <!-- Grelha de Ícones Visuais (Fica no Topo) -->\n  <div class=\"suevich-promise-grid\">\n    <div class=\"suevich-promise-item\">\n      <svg class=\"suevich-promise-icon\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375A1.125 1.125 0 012.25 17.625V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h1.125c.621 0 1.129-.504 1.09-1.124a17.902 17.902 0 00-3.213-9.193 2.056 2.056 0 00-1.58-.86H14.25M16.5 18.75h-2.25m0-11.25v5.25c0 .414.336.75.75.75h3.75\"></path></svg>\n      <span>{{ text_icon1 }}</span>\n    </div>\n    <div class=\"suevich-promise-item\">\n      <svg class=\"suevich-promise-icon\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z\"></path></svg>\n      <span>{{ text_icon2 }}</span>\n    </div>\n    <div class=\"suevich-promise-item\">\n      <svg class=\"suevich-promise-icon\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5\"></path></svg>\n      <span>{{ text_icon3 }}</span>\n    </div>\n    <div class=\"suevich-promise-item\">\n      <svg class=\"suevich-promise-icon\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99\"></path></svg>\n      <span>{{ text_icon4 }}</span>\n    </div>\n  </div>\n\n  <!-- Acordeão Nativo (details/summary) Que atua como Título Global -->\n  <details class=\"suevich-details\">\n    <summary class=\"suevich-summary\">\n      \n      <!-- Seta Esquerda -->\n      <svg class=\"suevich-accordion-icon-arrow\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"2\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19.5 8.25l-7.5 7.5-7.5-7.5\"></path></svg>\n      \n      <!-- Escudo e Título ao Centro -->\n      <div class=\"suevich-summary-content\">\n        <svg class=\"suevich-police-badge\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"1.5\" stroke=\"currentColor\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M9 12.75L11.25 15 15 9.75M21 12c0 7.5-9 10-9 10s-9-2.5-9-10V5.25L12 3l9 2.25V12z\" />\n        </svg>\n        <span>{{ text_title }}</span>\n      </div>\n\n      <!-- Seta Direita -->\n      <svg class=\"suevich-accordion-icon-arrow\" fill=\"none\" viewBox=\"0 0 24 24\" stroke-width=\"2\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M19.5 8.25l-7.5 7.5-7.5-7.5\"></path></svg>\n      \n    </summary>\n    <div class=\"suevich-details-content\">\n      <p>{{ text_intro }}</p>\n      <ul>\n        <li>{{ text_li1 }}</li>\n        <li>{{ text_li2 }}</li>\n        <li>{{ text_li3 }}</li>\n        <li>{{ text_li4 }}</li>\n      </ul>\n    </div>\n  </details>\n\n</div>"
          }
