<dynamic-dates
  class="estimated-shipping{% if block.settings.icon_alignment == 'middle' %} estimated-shipping--align-center{% endif %}"
  data-date-format="{{ block.settings.date_format }}"
  data-day-labels=""
  data-month-labels=""
  {{ block.shopify_attributes }}
  style="--margin-top: {{ block.settings.margin_top | divided_by: 10.0 }}rem;--margin-bottom: {{ block.settings.margin_bottom | divided_by: 10.0 }}rem;"
>
  {% unless block.settings.custom_icon == blank and block.settings.icon == blank %}
    <div class="estimated-shipping__icon estimated-shipping__icon--{{ block.settings.icon_size }}">
      {% if block.settings.custom_icon != blank %}
        <img
          src="{{ block.settings.custom_icon | image_url: width: 150 }}"
          width="auto"
          height="auto"
          loading="lazy"
        >
      {% else %}
        {% render 'material-icon', icon: block.settings.icon, filled: block.settings.filled_icon %}
      {% endif %}
    </div>
  {% endunless %}
  <div
    class="estimated-shipping__text estimated-shipping__text--{{ block.settings.text_size }}"
    data-dynamic-date="true"
    data-text="{{ block.settings.message }}"
    data-min-days="{{ block.settings.min_shipping_days }}"
    data-max-days="{{ block.settings.max_shipping_days }}"
  >
    {{ block.settings.message | replace: '[start_date]', '-' | replace: '[end_date]', '-' }}
  </div>

  <script>
    (function () {
      const parent = document.currentScript.parentElement;
      const textEl = parent.querySelector('.estimated-shipping__text');
      const locale = {{ localization.language.iso_code | json }} || 'en';
      const dateFormat = {{ block.settings.date_format | json }} || 'long';
      const minDays = parseInt(textEl.dataset.minDays, 10) || 0;
      const maxDays = parseInt(textEl.dataset.maxDays, 10) || 0;

      // Generate localized day/month labels for DynamicDates compatibility
      const dayFormatter = new Intl.DateTimeFormat(locale, { weekday: 'long' });
      const days = [];
      for (let i = 0; i < 7; i++) days.push(dayFormatter.format(new Date(2024, 0, i + 1)));
      parent.dataset.dayLabels = days.join(',');

      const monthFormatter = new Intl.DateTimeFormat(locale, { month: 'long' });
      const months = [];
      for (let i = 0; i < 12; i++) months.push(monthFormatter.format(new Date(2024, i, 1)));
      parent.dataset.monthLabels = months.join(',');

      // Calculate dates
      const today = new Date();
      const startDate = new Date(today); startDate.setDate(today.getDate() + minDays);
      const endDate = new Date(today); endDate.setDate(today.getDate() + maxDays);

      // Format based on selected format
      let startFormatted, endFormatted;
      switch (dateFormat) {
        case 'long':
          startFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long', year: 'numeric' }).format(endDate);
          break;
        case 'day_month':
          startFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long' }).format(endDate);
          break;
        case 'month_day':
          startFormatted = new Intl.DateTimeFormat(locale, { day: 'numeric', month: 'long' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { day: 'numeric', month: 'long' }).format(endDate);
          break;
        case 'medium':
          startFormatted = new Intl.DateTimeFormat(locale, { day: 'numeric', month: 'short', year: 'numeric' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { day: 'numeric', month: 'short', year: 'numeric' }).format(endDate);
          break;
        case 'numeric':
          startFormatted = new Intl.DateTimeFormat(locale, { day: '2-digit', month: '2-digit', year: 'numeric' }).format(startDate).replace(/\//g, '.');
          endFormatted = new Intl.DateTimeFormat(locale, { day: '2-digit', month: '2-digit', year: 'numeric' }).format(endDate).replace(/\//g, '.');
          break;
        case 'short':
          startFormatted = new Intl.DateTimeFormat(locale, { day: '2-digit', month: '2-digit', year: 'numeric' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { day: '2-digit', month: '2-digit', year: 'numeric' }).format(endDate);
          break;
        default:
          startFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long' }).format(startDate);
          endFormatted = new Intl.DateTimeFormat(locale, { weekday: 'short', day: 'numeric', month: 'long' }).format(endDate);
      }

      // Pre-bake dates into data-text so DynamicDates leaves them alone
      let bakedText = textEl.dataset.text || '';
      bakedText = bakedText.replace(/\[start_date\]/g, startFormatted);
      bakedText = bakedText.replace(/\[end_date\]/g, endFormatted);
      textEl.dataset.text = bakedText;

      // Carrier replacement logic
      const country = {{ localization.country.iso_code | json }};
      const carrierListRaw = {{ block.settings.carrier_list | json }};
      const carrierPrefix = {{ block.settings.carrier_prefix | json }};
      const carrierFallback = {{ block.settings.carrier_fallback | json }};

      const map = {};
      if (carrierListRaw) {
        carrierListRaw.split('\n').forEach(function (line) {
          const idx = line.indexOf(':');
          if (idx > -1) {
            const code = line.slice(0, idx).trim().toUpperCase();
            const name = line.slice(idx + 1).trim();
            map[code] = name;
          }
        });
      }

      const carrierName = map[country] || carrierFallback || '';
      const carrierDisplay = carrierName
        ? (carrierPrefix ? carrierPrefix + ' ' + carrierName : carrierName)
        : '';

      function applyCarrier() {
        if (!textEl.innerHTML.includes('[carrier]')) return;
        if (carrierDisplay) {
          textEl.innerHTML = textEl.innerHTML.replace(/\[carrier\]/g, carrierDisplay);
        } else {
          textEl.innerHTML = textEl.innerHTML.replace(/\s*\[carrier\]/g, '');
        }
      }

      const observer = new MutationObserver(function () {
        applyCarrier();
      });
      observer.observe(textEl, { childList: true, characterData: true, subtree: true });

      applyCarrier();
    })();
  </script>
</dynamic-dates>

{% schema %}
{
  "name": "t:blocks.estimated-shipping.name",
  "settings": [
    {
      "type": "text",
      "id": "icon",
      "default": "local_shipping",
      "label": "t:blocks.estimated-shipping.settings.icon.label",
      "info": "t:blocks.estimated-shipping.settings.icon.info"
    },
    {
      "type": "checkbox",
      "id": "filled_icon",
      "default": false,
      "label": "t:blocks.estimated-shipping.settings.filled_icon.label"
    },
    {
      "type": "image_picker",
      "id": "custom_icon",
      "label": "t:blocks.estimated-shipping.settings.custom_icon.label"
    },
    {
      "type": "select",
      "id": "icon_alignment",
      "options": [
        { "value": "top", "label": "t:blocks.estimated-shipping.settings.icon_alignment.options__1.label" },
        { "value": "middle", "label": "t:blocks.estimated-shipping.settings.icon_alignment.options__2.label" }
      ],
      "default": "top",
      "label": "t:blocks.estimated-shipping.settings.icon_alignment.label"
    },
    {
      "type": "richtext",
      "id": "message",
      "label": "t:blocks.estimated-shipping.settings.message.label",
      "default": "<p>Get it between <strong>[start_date]</strong> and <strong>[end_date]</strong></p>",
      "info": "t:blocks.estimated-shipping.settings.message.info"
    },
    {
      "type": "radio",
      "id": "icon_size",
      "label": "t:blocks.estimated-shipping.settings.icon_size.label",
      "options": [
        { "value": "small", "label": "t:blocks.estimated-shipping.settings.icon_size.options__1.label" },
        { "value": "medium", "label": "t:blocks.estimated-shipping.settings.icon_size.options__2.label" },
        { "value": "large", "label": "t:blocks.estimated-shipping.settings.icon_size.options__3.label" }
      ],
      "default": "medium"
    },
    {
      "type": "radio",
      "id": "text_size",
      "label": "t:blocks.estimated-shipping.settings.text_size.label",
      "options": [
        { "value": "small", "label": "t:blocks.estimated-shipping.settings.text_size.options__1.label" },
        { "value": "medium", "label": "t:blocks.estimated-shipping.settings.text_size.options__2.label" },
        { "value": "large", "label": "t:blocks.estimated-shipping.settings.text_size.options__3.label" }
      ],
      "default": "medium"
    },
    {
      "type": "textarea",
      "id": "carrier_list",
      "label": "t:blocks.estimated-shipping.settings.carrier_list.label",
      "default": "DE: DHL Standard Shipping (CAINIAO)\nBR: Correios Frete Segurado",
      "info": "t:blocks.estimated-shipping.settings.carrier_list.info"
    },
    {
      "type": "select",
      "id": "carrier_prefix",
      "label": "t:blocks.estimated-shipping.settings.carrier_prefix.label",
      "default": "with",
      "info": "t:blocks.estimated-shipping.settings.carrier_prefix.info",
      "options": [
        { "value": "with", "label": "t:blocks.estimated-shipping.settings.carrier_prefix.options__1.label" },
        { "value": "mit", "label": "t:blocks.estimated-shipping.settings.carrier_prefix.options__2.label" },
        { "value": "com", "label": "t:blocks.estimated-shipping.settings.carrier_prefix.options__3.label" },
        { "value": "avec", "label": "t:blocks.estimated-shipping.settings.carrier_prefix.options__4.label" },
        { "value": "con", "label": "t:blocks.estimated-shipping.settings.carrier_prefix.options__5.label" },
        { "value": "met", "label": "t:blocks.estimated-shipping.settings.carrier_prefix.options__6.label" },
        { "value": "via", "label": "t:blocks.estimated-shipping.settings.carrier_prefix.options__7.label" },
        { "value": "por", "label": "t:blocks.estimated-shipping.settings.carrier_prefix.options__8.label" },
        { "value": "", "label": "t:blocks.estimated-shipping.settings.carrier_prefix.options__9.label" }
      ]
    },
    {
      "type": "text",
      "id": "carrier_fallback",
      "label": "t:blocks.estimated-shipping.settings.carrier_fallback.label",
      "default": "Standard Shipping",
      "info": "t:blocks.estimated-shipping.settings.carrier_fallback.info"
    },
    {
      "type": "number",
      "id": "min_shipping_days",
      "label": "t:blocks.estimated-shipping.settings.min_shipping_days.label",
      "default": 7
    },
    {
      "type": "number",
      "id": "max_shipping_days",
      "label": "t:blocks.estimated-shipping.settings.max_shipping_days.label",
      "default": 15
    },
    {
      "type": "radio",
      "id": "date_format",
      "label": "t:blocks.estimated-shipping.settings.date_format.label",
      "options": [
        { "value": "long", "label": "t:blocks.estimated-shipping.settings.date_format.options__1.label" },
        { "value": "day_month", "label": "t:blocks.estimated-shipping.settings.date_format.options__2.label" },
        { "value": "month_day", "label": "t:blocks.estimated-shipping.settings.date_format.options__3.label" },
        { "value": "medium", "label": "t:blocks.estimated-shipping.settings.date_format.options__4.label" },
        { "value": "numeric", "label": "t:blocks.estimated-shipping.settings.date_format.options__5.label" },
        { "value": "short", "label": "t:blocks.estimated-shipping.settings.date_format.options__6.label" }
      ],
      "default": "long"
    },
    {
      "type": "header",
      "content": "t:blocks.estimated-shipping.settings.header__1.content"
    },
    {
      "type": "header",
      "content": "t:blocks.estimated-shipping.settings.header__2.content"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "label": "t:blocks.estimated-shipping.settings.margin_top.label",
      "default": 24
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 45,
      "step": 3,
      "unit": "px",
      "label": "t:blocks.estimated-shipping.settings.margin_bottom.label",
      "default": 24
    }
  ]
}
{% endschema %}
