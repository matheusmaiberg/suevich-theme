        "custom_liquid": "{%- liquid\n  # 1. Obter o mês atual (de 1 a 12) e o idioma\n  assign current_month = 'now' | date: \"%m\" | plus: 0\n  assign language = request.locale.iso_code\n  \n  # 2. Detetar o Hemisfério automaticamente com base no país do visitante\n  assign country_code = localization.country.iso_code\n  # Lista dos principais países do Hemisfério Sul (códigos ISO)\n  assign paises_sul = 'BR,AU,AR,ZA,NZ,CL,PE,UY,PY,BO,AO,MZ' | split: ','\n\n  if paises_sul contains country_code\n    assign hemisphere = 'south'\n  else\n    assign hemisphere = 'north'\n  endif\n\n  # 3. Lógica automática das estações com base no mês e hemisfério\n  if hemisphere == 'south'\n    if current_month >= 3 and current_month <= 5\n      assign season_pt = \"O Outono\"\n      assign season_en = \"Autumn\"\n      assign season_de = \"Der Herbst\"\n    elsif current_month >= 6 and current_month <= 8\n      assign season_pt = \"O Inverno\"\n      assign season_en = \"Winter\"\n      assign season_de = \"Der Winter\"\n    elsif current_month >= 9 and current_month <= 11\n      assign season_pt = \"A Primavera\"\n      assign season_en = \"Spring\"\n      assign season_de = \"Der Frühling\"\n    else\n      assign season_pt = \"O Verão\"\n      assign season_en = \"Summer\"\n      assign season_de = \"Der Sommer\"\n    endif\n  else\n    if current_month >= 3 and current_month <= 5\n      assign season_pt = \"A Primavera\"\n      assign season_en = \"Spring\"\n      assign season_de = \"Der Frühling\"\n    elsif current_month >= 6 and current_month <= 8\n      assign season_pt = \"O Verão\"\n      assign season_en = \"Summer\"\n      assign season_de = \"Der Sommer\"\n    elsif current_month >= 9 and current_month <= 11\n      assign season_pt = \"O Outono\"\n      assign season_en = \"Autumn\"\n      assign season_de = \"Der Herbst\"\n    else\n      assign season_pt = \"O Inverno\"\n      assign season_en = \"Winter\"\n      assign season_de = \"Der Winter\"\n    endif\n  endif\n\n  # 4. Construção das frases finais com o idioma detetado\n  case language\n    when 'en'\n      assign msg_estacao = season_en | append: \" is here, it's time for a wardrobe upgrade!\"\n      assign msg_frete = \"Free shipping\"\n    when 'de'\n      assign msg_estacao = season_de | append: \" ist da, Zeit für ein Upgrade deiner Garderobe!\"\n      assign msg_frete = \"Kostenloser Versand\"\n    else\n      assign msg_estacao = season_pt | append: \" chegou, está na hora de um upgrade no seu guarda-roupa!\"\n      assign msg_frete = \"Frete grátis\"\n  endcase\n-%}\n\n<!-- Estrutura HTML -->\n<div class=\"announcement-bar-custom\" id=\"announcement-bar\">\n  <div class=\"announcement-message active\" data-index=\"0\">\n    <p>{{ msg_estacao }}</p>\n  </div>\n  <div class=\"announcement-message\" data-index=\"1\">\n    <p>{{ msg_frete }}</p>\n  </div>\n</div>\n\n<!-- Estilos CSS -->\n<style>\n  .announcement-bar-custom {\n    background-color: #000;\n    color: #fff;\n    padding: 0 10px;\n    text-align: center;\n    font-size: 14px;\n    height: 35px; /* Altura exata de 35px */\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    overflow: hidden;\n    position: relative;\n    text-transform: uppercase;\n    letter-spacing: 1px;\n  }\n\n  .announcement-message {\n    position: absolute;\n    width: 100%;\n    opacity: 0;\n    transition: all 0.6s ease-in-out;\n    transform: translateY(10px);\n    visibility: hidden;\n  }\n\n  .announcement-message.active {\n    opacity: 1;\n    visibility: visible;\n    transform: translateY(0);\n  }\n\n  .announcement-message p {\n    margin: 0;\n    padding: 0 20px;\n    font-weight: 600;\n  }\n</style>\n\n<!-- Script de Animação -->\n<script>\n  document.addEventListener('DOMContentLoaded', function() {\n    const messages = document.querySelectorAll('.announcement-message');\n    if (messages.length > 1) {\n      let currentIndex = 0;\n      setInterval(function() {\n        messages[currentIndex].classList.remove('active');\n        currentIndex = (currentIndex + 1) % messages.length;\n        messages[currentIndex].classList.add('active');\n      }, 5000); // Rotação a cada 5 segundos\n    }\n  });\n</script>",
