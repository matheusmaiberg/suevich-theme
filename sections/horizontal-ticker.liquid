      "min": 1,
      "max": 5,
      "default": 3,
      "step": 0.5
    },
    {
      "type": "number",
      "id": "mobile_spacing",
      "label": "t:sections.horizontal-ticker.settings.visibility.label",
      "default": 60
    },
    {
      "type": "number",
      "id": "desktop_spacing",
      "label": "t:sections.horizontal-ticker.settings.visibility.label",
      "default": 100
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
