      "default": 16,
      "label": "t:sections.horizontal-ticker.settings.visibility.label"
    },
    {
      "type": "range",
      "id": "desktop_text_size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 18,
      "label": "t:sections.horizontal-ticker.settings.visibility.label"
    },
    {
      "type": "checkbox",
      "id": "italic_text",
      "label": "t:sections.horizontal-ticker.settings.visibility.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "uppercase_text",
      "label": "t:sections.horizontal-ticker.settings.visibility.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "bold_text",
      "label": "t:sections.horizontal-ticker.settings.visibility.label",
      "default": false
    },
    {
      "type": "header",
